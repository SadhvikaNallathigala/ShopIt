        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\":\"John Doe\",\n    \"email\":\"john@example.com\",\n    \"password\":\"Password@123\"\n}"
            },
            "url": {
              "raw": "{{crmUrl}}/api/auth/register",
              "host": [
                "{{crmUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
