          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\":\"Laptop\",\n    \"description\":\"Gaming Laptop\",\n    \"price\":65000,\n    \"stock\":10\n}"
            },
            "url": {
              "raw": "{{ecommerceUrl}}/api/products",
              "host": [
                "{{ecommerceUrl}}"
              ],
              "path": [
                "api",
                "products"
              ]
            }
          }
        }
      ]
    },
